# 环境变量示例（可选）
# 复制为 .env 并根据需要修改

# 路径配置（相对仓库根目录）
# ZIKAO_COURSES_DIR=content/{province}/courses
# ZIKAO_MAJORS_DIR=content/{province}/majors
# ZIKAO_TEMPLATES_DIR=scripts/templates
# ZIKAO_OUT_DIR=site/courses
# ZIKAO_SITE_DIR=site

# 外链监控配置
# ZIKAO_BASELINE=ops/{province}/source-links.baseline.json
# ZIKAO_REPORT=site/source-link-report.md
# ZIKAO_SUMMARY=site/source-link-report.json

# 构建元信息
# ZIKAO_BUILD_TIME=auto
# ZIKAO_GIT_COMMIT=auto
